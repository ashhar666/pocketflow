# PocketFlow Environment Variables Template
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# ── Django Core ─────────────────────────────────────────────────────
# Generate a new one: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-super-secret-django-key-change-in-production

# Set to False in production (defaults to False if not provided)
DEBUG=True

# Comma-separated list of allowed hosts (no wildcards in production)
ALLOWED_HOSTS=localhost,127.0.0.1

# ── CORS ─────────────────────────────────────────────────────────────
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_ALL_ORIGINS=False

# ── Database ──────────────────────────────────────────────────────
# SQLite (Development):
DATABASE_URL=sqlite:///db.sqlite3

# PostgreSQL (Production - Supabase example):
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
# DATABASE_URL=postgresql://postgres.xxx:password@aws-0-region.pooler.supabase.com:6543/postgres

# ── Frontend URL ───────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Gmail SMTP ──────────────────────────────────────────────────────
# 1. Enable 2FA on your Google Account
# 2. Create App Password: https://myaccount.google.com/apppasswords
# 3. Use your Gmail email as EMAIL_HOST_USER
# 4. Set EMAIL_HOST_PASSWORD to the 16-character App Password (no spaces)
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-app-password
DEFAULT_FROM_EMAIL=PocketFlow <your-email@gmail.com>

# ── Telegram Bot ───────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram, then paste the token here
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_BOT_USERNAME=YourBotUsername
# TELEGRAM_WEBHOOK_URL=https://your-tunnel.ngrok-free.dev/api/telegram/webhook/
# A random secret string to verify Telegram's webhook requests.
# Header verified: X-Telegram-Bot-Api-Secret-Token
TELEGRAM_WEBHOOK_SECRET=your_random_secret_string

# ── Google Gemini (AI Receipt Scanning) ───────────────────────────
# Create an API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key
